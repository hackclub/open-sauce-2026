---
import Layout from "../layouts/Layout.astro";
import Landing from "../content/landing.md";
import HeroProject from "../components/HeroProject.astro";
---

<Layout>
    <div class="hero flex flex-col relative overflow-hidden">
        <nav class="flex items-center px-8 py-4 bg-[#3B312F]">
            <a href="/"><img src="/outposttext.svg" class="h-6" /></a>
        </nav>

        <div
            class="flex-1 flex items-center justify-center mb-44 relative z-10"
        >
            <img
                src="/checkcorner.svg"
                class="absolute top-0 right-0 w-32 xl:w-xs opacity-80"
            />

            <img
                src="/checkcorner.svg"
                class="absolute top-0 left-0 w-32 xl:w-xs opacity-80 scale-x-[-1]"
            />

            <div class="flex flex-col items-center mx-5">
                <div class="flex flex-row space-x-6 items-center md:-mb-8">
                    <a href="https://hackclub.com"
                        ><img
                            src="/hackclub.png"
                            class="h-10 hover:-rotate-5 hover:scale-102 transition"
                        /></a
                    >
                    <img src="/with.svg" class="h-6" />
                    <a href="https://www.opensauce.com/"
                        ><img
                            src="/opensauce.png"
                            class="h-20 hover:rotate-5 hover:scale-102 transition"
                        /></a
                    >
                </div>

                <img src="/outpost.png" class="max-w-5xl w-full" />
                <div class="mt-4 text-xl md:text-2xl text-center text-balance">
                    <p>
                        3 day hackathon followed by a 2 day showcase at <a
                            href="https://www.opensauce.com/"
                            class="link">Open Sauce</a
                        >!
                    </p>
                    <p>
                        Make 12 points of hardware projects in <a
                            href="https://stardance.hackclub.com"
                            class="link">Stardance Challenge</a
                        > to qualify.
                    </p>
                </div>
                <p class="text-3xl mt-8 text-center mx-10 text-balance">
                    More information coming soon!
                </p>
            </div>
        </div>

        <div
            class="absolute -right-10 xl:right-0 bottom-0 scale-44 md:scale-50 xl:scale-75 2xl:scale-100 origin-bottom-right"
        >
            <HeroProject
                src="/projects/hardware_flight.png"
                class="bottom-100 right-0 w-3xs"
                description=""
            />
            <HeroProject
                src="/projects/hardware_twoswap.png"
                class="absolute bottom-54 right-0 w-xs"
                description=""
            />
            <HeroProject
                src="/projects/hardware_defusal.png"
                class="absolute bottom-0 right-0 w-lg"
                description=""
            />
            <HeroProject
                src="/projects/hardware_drone.png"
                class="absolute bottom-24 right-44 w-lg"
                description=""
            />
            <HeroProject
                src="/projects/hardware1.png"
                class="absolute bottom-0 right-100 w-sm"
                description=""
            />
        </div>

        <div
            class="absolute -left-10 xl:left-0 bottom-0 scale-44 md:scale-50 xl:scale-75 2xl:scale-100 origin-bottom-left"
        >
            <HeroProject
                src="/projects/hardware_board.png"
                class="absolute bottom-0 left-72 w-sm"
                description=""
            />
            <HeroProject
                src="/projects/hardware_toast.png"
                class="absolute bottom-0 left-125 w-3xs"
                description=""
            />
            <HeroProject
                src="/projects/hardware_split.png"
                class="absolute bottom-64 left-0 w-sm"
                description=""
            />
            <HeroProject
                src="/projects/hardware_jukebox.png"
                class="absolute bottom-44 left-0 w-2xs"
                description=""
            />
            <HeroProject
                src="/projects/hardware_car.png"
                class="absolute bottom-0 left-0 w-md"
                description=""
            />
            <HeroProject
                src="/projects/hardware_ducky.png"
                class="absolute bottom-16 left-68 w-xs"
                description=""
            />
            <HeroProject
                src="/projects/hardware_bobby.png"
                class="absolute bottom-125 left-0 w-3xs"
                description=""
            />
        </div>
    </div>

    <div class="">
        <img src="/dividerstripped.svg" class="w-full h-20 md:h-auto object-cover" />
    </div>

    <div class="py-24 bg-[#FCF3DE] text-[#3B312F]">
        <div class="flex flex-col items-center mx-5">
            <div class="mb-8 text-center">
                <p class="text-4xl germania">
                    The greatest hardware adventure yet.
                </p>
                <p class="text-xl mt-2">This event is split into three parts:</p>
            </div>


            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <div
                    class="bg-[#FEAB01] rounded border-dashed p-8 lg:translate-x-8 h-full max-w-lg relative"
                >
                    <p class="text-3xl mb-4 germania">
                        Part 1: make hardware projects!
                    </p>
                    <p class="text-xl">
                        Design the PCB and CAD to your hardware projects in <a
                            href="https://stardance.hackclub.com"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-[#3B312F] hover:underline font-bold link"
                            >Stardance</a
                        >, Hack Club's summer program! 
                        
                        <p class="text-xl mt-4">Submit your design to [OUTPOST] to get a grant up to 350 USD 
                        to purchase the parts for your project.</p>
                        
                        <p class="text-xl mt-4">Then, build your project irl! After you ship the build, you'll earn points to qualify for the Outpost Hackathon.</p>
                    </p>
                    <p class="absolute px-4 py-2 rounded text-2xl -top-8 -left-6 -rotate-2 bg-[#3B312F] text-[#FE5100] germania">June [X] - July 31</p>
                </div>

                <div class="relative *:border-4 *:border-[#FEAB01]">
                    <img src="/info1.png" class="max-w-lg rounded w-full h-full object-cover lg:translate-x-8"/>
                    <img src="/hackapet.png" class="absolute max-w-44 rounded -top-10 -right-9 z-10 rotate-2 hidden md:block"/>
                    <img src="/hackpadcase.png" class="absolute max-w-44 rounded top-32 -right-24 z-10 -rotate-2 hidden md:block"/>
                </div>

                <img
                    src="/info1.png"
                    class="max-w-lg rounded w-full h-full object-cover lg:-translate-x-8"
                />
                <div
                    class="bg-[#FE9802] rounded border-dashed p-8 lg:-translate-x-8 h-full max-w-lg relative"
                >
                    <p class="text-3xl mb-4 germania">
                        Part 2: Outpost Hackathon!
                    </p>
                    <p class="text-xl">
                        Outpost is a 48h hardware hackathon in San Francisco! You'll be in a
                        group of teens and try making a project from start to
                        finish.
                    </p>
                    <p class="text-xl mt-4">
                        During this time, you'll also be fixing up your
                        stardance hardware projects that might've gotten broken
                        in transport in preparation for the Opensauce showcase!
                    </p>
                    <p class="absolute px-4 py-2 rounded text-2xl -top-2 -right-6 rotate-2 bg-[#3B312F] text-[#FE5100] germania">July 15 - 17</p>
                </div>

                <div
                    class="bg-[#FE8002] rounded border-dashed p-8 lg:translate-x-8 h-full max-w-lg"
                >
                    <p class="text-3xl mb-4 germania">
                        Part 3: Showcase at Open Sauce!
                    </p>
                    <p class="text-xl">
                        Here, you will spend 2 days at a booth with a few other
                        teens showcasing both your hackathon and your Stardance
                        hardware projects.
                    </p>
                    <p class="text-xl mt-4">
                        Open Sauce is the world's biggest maker faire, with a
                        bunch of engineering creators there too! There's plenty
                        of talks and panels, as well as other booths you can
                        check out.
                    </p>
                    <p class="absolute px-4 py-2 rounded text-2xl -top-6 -left-6 -rotate-2 bg-[#3B312F] text-[#FE5100] germania">July 18 - 19</p>
                </div>
                <img
                    src="/info1.png"
                    class="max-w-lg rounded w-full h-full object-cover lg:translate-x-8"
                />
            </div>
        </div>
    </div>






    <div class="py-24 bg-[#3B312F]">


        
        <div class="flex flex-col items-center text-[#FCF3DE]">
            <p class="text-4xl mb-4 text-[#FE5100] germania">How can I join?</p>
            <p>join the slack channel!!!! [#slack channel yipeee]</p>
        </div>

        <div class="flex flex-col items-center mt-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 *:border-4 *:rounded *:p-8 text-[#FCF3DE] max-w-6xl w-full">
                <div class="border-[#FEAB01]">
                    <p class="text-2xl germania">4 point project (small)</p>
                </div>
                <div class="border-[#FEAB01]">
                    <p class="text-2xl germania">12 point project (medium)</p>
                </div>
                <div class="border-[#FEAB01]">
                    <p class="text-2xl germania">20 point project (complex)</p>
                </div>
            </div>
        </div>





    </div>






    <div class="py-24 flex flex-col items-center bg-[#FCF3DE] text-[#3B312F]">
        <div class="mb-8 text-center">
            <p class="text-4xl text-balance germania">
                What does a hardware hackathon look like?
            </p>
            <p class="mt-2 text-xl">
                Check out <a href="https://undercity.hackclub.com" class="link germania">Undercity</a>, a 4-day hardware hackathon we hosted at GitHub HQ last year!
            </p>    
        </div>


        <iframe
            src="https://www.youtube.com/embed/kaEFv7e49mo"
            class="w-[60%] aspect-video rounded-lg"
            allowfullscreen></iframe>
    </div>




    <div class="py-24 flex flex-col items-center bg-[#FCF3DE] text-[#3B312F]">
        <div class="mb-8 text-center">
            <p class="text-4xl text-balance germania">20 booths. 80 teenagers. You're invited.</p>
            <p class="text-4xl text-balance germania">
                Ready to get started?
            </p>
            <p class="mt-2 text-xl">
                INSERT CTA HERE
            </p>    
        </div>
    </div>







    <div class="py-16 bg-[#3B312F]">

        <div class="flex flex-col items-center text-[#FCF3DE] px-5">
            <div class="grid md:grid-cols-[auto_1fr] gap-8 max-w-6xl w-full">
                
                <div class="flex flex-col items-center md:items-end">
                    <img src="/outpost.png" class="max-w-xs" />

                    <div class="grid grid-cols-2 text-2xl germania mt-4">
                        <p class="text-right pr-4"><a href="https://hackclub.com" class="hover:underline">Hack Club</a></p>
                        <p class="text-left pl-4"><a href="https://stardance.hackclub.com" class="hover:underline">Stardance</a></p>
                        <p class="text-right pr-4"><a href="https://slack.hackclub.com/" class="hover:underline">Slack</a></p>
                        <p class="text-left pl-4"><a href="https://hackclub.com/clubs" class="hover:underline">Clubs</a></p>
                        <p class="text-right pr-4"><a href="https://hackathons.hackclub.com/" class="hover:underline">Hackathons</a></p>
                    </div>
                </div>

                <div class="flex flex-col gap-4 justify-center text-lg opacity-80">
                    <p>
                        Hack Club is a 501(c)(3) nonprofit and network of 100k+ technical high schoolers. 
                        We believe you learn best by building, so we're creating community and providing grants so you can make awesome projects. 
                        In the past few years, we've sent 
                        <a href="https://www.youtube.com/watch?v=ufMUJ9D1fi8" class="link">30 teen hackers hiking the Pacific Crest Trail</a>
                        , 
                        <a href="https://www.youtube.com/watch?v=8iM1W8kXrQA" class="link">hosted a hackathon for the worst ideas</a>
                        , and ran the 
                        <a href="https://www.youtube.com/watch?v=kaEFv7e49mo" class="link">largest hardware hackathon at GitHub HQ</a>
                        .
                    </p>
                    <p>
                        Read about Hack Club in 
                        <a href="https://www.wsj.com/articles/teen-hackers-try-to-convince-parents-they-are-up-to-good-11569922200" class="link">The Wall Street Journal</a>, 
                        <a href="https://www.cbsnews.com/sanfrancisco/news/hack-club-hosts-teen-coders-san-francisco/" class="link">CBS News</a>, and 
                        <a href="https://www.nasa.gov/learning-resources/space-out-this-summer-with-variety-of-nasa-stem-activities/" class="link">NASA.gov</a>, or watch us 
                        <a href="https://www.youtube.com/live/UbfAhFxDomE?si=5DiK1_hGqKrB_r50&t=7033" class="link">on stage with AMD CEO Lisa Su at CES</a>.
                    </p>
                    <p>
                        Made with ♥︎ by teenagers, for teenagers at Hack Club
                    </p>
                </div>

            </div>
        </div>













    </div>

    {
        /* <a
            href="https://hackclub.com"
            target="_blank"
            rel="noopener noreferrer"
            class="absolute top-0 left-4 md:left-10 z-10"
        >
            <img
                src="https://assets.hackclub.com/flag-orpheus-top.svg"
                alt="Hack Club"
                class="w-20 md:w-32"
            />
        </a>
        <div
            class="max-w-2xl mx-auto px-4 my-16 md:my-24 font-serif font-semibold items-start flex flex-col"
        >
            <div class="prose-lg">
                <Landing />
            </div>
            <div class="mt-8">
                <a
                    href="/info/overview"
                    class="bg-amber-800 hover:bg-amber-900 text-taupe-100 font-bold py-2 px-4 rounded transition duration-200"
                    >Get Started ➔</a
                >
            </div>
            <div class="prose my-12 text-taupe-900">
                <p>
                    Have questions? You should probably check out the <a
                        href="/info/faq">FAQ</a
                    >
                </p>
            </div>
        </div>*/
    }
</Layout>
