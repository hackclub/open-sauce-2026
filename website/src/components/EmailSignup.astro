---
const { class: className = "" } = Astro.props;
---

<form
    class:list={["email-signup mt-8 mx-10 w-full max-w-xl", className]}
    method="POST"
    action="/api/signup"
    novalidate
>
    <div class="flex flex-col sm:flex-row gap-3 items-stretch justify-center">
        <input
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="you@example.com"
            class="signup-email flex-1 text-2xl px-4 py-2 rounded bg-white text-[#3B312F] border-2 border-[#3B312F] placeholder:text-[#3B312F]/50 focus:outline-none focus:ring-2 focus:ring-[#34E0BA]"
        />
        <button
            type="submit"
            class="signup-submit text-3xl text-center px-6 py-2 bg-[#3B312F] text-[#34E0BA] rounded hover:scale-105 transition duration-150 striped disabled:opacity-60 disabled:hover:scale-100"
        >
            SIGN UP
        </button>
    </div>
    <p
        class="signup-status text-center text-lg mt-2 min-h-[1.5rem]"
        aria-live="polite"
    >
    </p>
</form>

<script>
    document
        .querySelectorAll<HTMLFormElement>("form.email-signup")
        .forEach((form) => {
            const status = form.querySelector(".signup-status") as HTMLElement;
            const submit = form.querySelector(
                ".signup-submit",
            ) as HTMLButtonElement;
            const input = form.querySelector(
                ".signup-email",
            ) as HTMLInputElement;

            form.addEventListener("submit", async (e) => {
                e.preventDefault();
                const email = input.value.trim();
                status.style.color = "#3B312F";
                status.textContent = "Signing you up…";
                submit.disabled = true;

                try {
                    const res = await fetch("/api/signup", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ email }),
                    });
                    const data = await res.json().catch(() => ({}));
                    if (res.ok) {
                        status.textContent = "Email sent! Check your inbox :D";
                        form.reset();
                    } else {
                        status.style.color = "#b91c1c";
                        status.textContent =
                            data.error ?? "Something went wrong.";
                    }
                } catch {
                    status.style.color = "#b91c1c";
                    status.textContent = "Network error. Please try again.";
                } finally {
                    submit.disabled = false;
                }
            });
        });
</script>
