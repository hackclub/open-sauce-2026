---
import { DOCS } from "../data/docs";

const currentSlug = Astro.url.pathname
    .replace(/^\/info\//, "")
    .replace(/\/$/, "");

const currentDoc = DOCS.find((d) => d.slug === currentSlug);
---

<details class="md:hidden border-b border-stone-400/40 group">
    <summary
        class="cursor-pointer list-none px-4 py-3 flex items-center justify-between font-semibold text-stone-900"
    >
        <span class="flex items-center gap-3">
            <svg
                class="w-5 h-5 group-open:hidden"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg
                class="w-5 h-5 hidden group-open:block"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
            <span>Menu</span>
        </span>
        <span class="text-sm text-stone-500 font-normal">
            {currentDoc?.title}
        </span>
    </summary>
    <nav class="flex flex-col gap-1 px-4 pb-4">
        <a
            href="/"
            class="block px-3 py-1.5 rounded text-sm font-semibold text-stone-600 hover:text-stone-900 hover:bg-stone-800/5"
            >← Back to home</a
        >
        {
            DOCS.map((d) => (
                <a
                    href={`/info/${d.slug}`}
                    class:list={[
                        "block px-3 py-1.5 rounded text-sm",
                        d.slug === currentSlug
                            ? "bg-stone-800/10 font-bold text-stone-900"
                            : "text-stone-700 hover:bg-stone-800/5 font-semibold",
                    ]}
                >
                    {d.title}
                </a>
            ))
        }
    </nav>
</details>

<aside
    class="hidden md:block md:fixed md:top-0 md:left-0 md:w-56 md:h-screen md:overflow-y-auto md:border-r md:border-stone-400/40 md:p-6"
>
    <a
        href="/"
        class="block mb-8 text-sm text-stone-600 hover:text-stone-900 font-semibold"
        >← Back</a
    >
    <nav class="flex flex-col gap-1">
        {
            DOCS.map((d) => (
                <a
                    href={`/info/${d.slug}`}
                    class:list={[
                        "block px-3 py-1.5 rounded text-sm",
                        d.slug === currentSlug
                            ? "bg-stone-800/10 font-bold text-stone-900"
                            : "text-stone-700 hover:bg-stone-800/5 font-semibold",
                    ]}
                >
                    {d.title}
                </a>
            ))
        }
    </nav>
</aside>
